# ─────────────────────────────────────────────────────────────
# screenshot-rename environment config
# Copy this file to ~/.screenshot-rename.env and add your key
#
# Usage: cp .screenshot-rename.env.example ~/.screenshot-rename.env
# ─────────────────────────────────────────────────────────────

# ── Claude / Anthropic (default) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Google Gemini ─────────────────────────────────────────────
# GEMINI_API_KEY=...

# ── Groq ─────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── Ollama (local — no key needed) ───────────────────────────
# No key required. Just make sure Ollama is running:
# ollama serve
# And that your chosen model is pulled:
# ollama pull llava
